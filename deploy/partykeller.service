# systemd-Unit für den Raspberry Pi
# Installation: siehe deploy/PI-SETUP.md
[Unit]
Description=Partykeller Getraenke-Counter
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/partykeller-counter
EnvironmentFile=/home/pi/partykeller-counter/.env
ExecStart=/usr/bin/node server/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
