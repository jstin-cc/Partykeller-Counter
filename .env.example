# Kopieren nach .env und Werte setzen — der Server startet nicht ohne
# ADMIN_PASSWORD und TOKEN_SECRET.

# Port des Servers (ein Prozess für alle Views + API + WebSocket)
PORT=3000

# Admin-Passwort für /partykeller/admin (D-003: nie im Code)
ADMIN_PASSWORD=

# Eigenes Admin-Passwort für den Youngstars-Bereich /youngstars/admin (D-019)
YOUNGSTARS_ADMIN_PASSWORD=

# Eigenes Passwort für „Alles zurücksetzen" (getrennt vom Admin-Login, D-013).
# Leer lassen => es gilt ADMIN_PASSWORD. Für eine echte Trennung anderen Wert setzen.
RESET_PASSWORD=

# Secret zum Signieren der Login-Tokens (D-006), z. B.:
#   openssl rand -hex 32
TOKEN_SECRET=

# Pfade zu den SQLite-Datenbanken (eine je Bereich, D-019)
DB_PATH=data/partykeller.db
YOUNGSTARS_DB_PATH=data/youngstars.db
